<nav class="my-4">
  Table of contents
</nav>

<main class="my-4">
  <ul>
    <% pages.each do |page| %>
      <li class="my-2">
        <a href="<%= page["page_path"] %>"><%= page["title"] %></a>
        <% if page["published_at"] %>
          <small class="text-muted"><time datetime="<%= page["published_at"].to_time %>"><%= page["published_at"].strftime("%Y/%m/%d") %></time></small>
        <% end %>
      </li>
    <% end %>
  </ul>
</main>
